{
  "$id": "PlayerMoveData",
  "description": "Player movement update payload",
  "type": "object",
  "required": [
    "players"
  ],
  "properties": {
    "players": {
      "description": "Array of player states",
      "type": "array",
      "items": {
        "$id": "PlayerState",
        "description": "Player state for movement updates",
        "type": "object",
        "required": [
          "id",
          "position",
          "velocity",
          "aimAngle",
          "health",
          "isInvulnerable",
          "invulnerabilityEnd",
          "kills",
          "deaths",
          "xp",
          "isRegenerating",
          "isRolling"
        ],
        "properties": {
          "id": {
            "description": "Player unique identifier",
            "minLength": 1,
            "type": "string"
          },
          "position": {
            "description": "A 2D position coordinate",
            "type": "object",
            "required": [
              "x",
              "y"
            ],
            "properties": {
              "x": {
                "description": "X coordinate",
                "type": "number"
              },
              "y": {
                "description": "Y coordinate",
                "type": "number"
              }
            }
          },
          "velocity": {
            "description": "A 2D velocity vector",
            "type": "object",
            "required": [
              "x",
              "y"
            ],
            "properties": {
              "x": {
                "description": "X velocity component",
                "type": "number"
              },
              "y": {
                "description": "Y velocity component",
                "type": "number"
              }
            }
          },
          "aimAngle": {
            "description": "Player aim angle in radians",
            "type": "number"
          },
          "health": {
            "description": "Current health",
            "minimum": 0,
            "type": "number"
          },
          "isInvulnerable": {
            "description": "Whether spawn invulnerability is active",
            "type": "boolean"
          },
          "invulnerabilityEnd": {
            "description": "RFC3339 timestamp when invulnerability ends",
            "type": "string"
          },
          "deathTime": {
            "description": "RFC3339 timestamp when the player died",
            "type": "string"
          },
          "kills": {
            "description": "Current kill count",
            "minimum": 0,
            "type": "integer"
          },
          "deaths": {
            "description": "Current death count",
            "minimum": 0,
            "type": "integer"
          },
          "xp": {
            "description": "Current XP total",
            "minimum": 0,
            "type": "integer"
          },
          "isRegenerating": {
            "description": "Whether the player is currently regenerating health",
            "type": "boolean"
          },
          "isRolling": {
            "description": "Whether the player is currently dodge rolling",
            "type": "boolean"
          }
        }
      }
    },
    "lastProcessedSequence": {
      "description": "Map of player IDs to their last processed input sequence number for client-side prediction reconciliation",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {
          "description": "Last processed input sequence number for this player",
          "minimum": 0,
          "type": "number"
        }
      }
    },
    "correctedPlayers": {
      "description": "Array of player IDs whose positions were corrected by the server due to impossible movement detection",
      "type": "array",
      "items": {
        "minLength": 1,
        "type": "string"
      }
    }
  }
}
