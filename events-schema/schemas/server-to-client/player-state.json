{
  "$id": "PlayerState",
  "description": "Player state for movement updates",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "position",
    "velocity",
    "aimAngle",
    "weaponType",
    "health",
    "isInvulnerable",
    "invulnerabilityEnd",
    "kills",
    "deaths",
    "xp",
    "isRegenerating",
    "isRolling"
  ],
  "properties": {
    "id": {
      "description": "Player unique identifier",
      "minLength": 1,
      "type": "string"
    },
    "displayName": {
      "description": "Authoritative display name for rendering",
      "minLength": 1,
      "type": "string"
    },
    "position": {
      "description": "A 2D position coordinate",
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "description": "X coordinate",
          "type": "number"
        },
        "y": {
          "description": "Y coordinate",
          "type": "number"
        }
      }
    },
    "velocity": {
      "description": "A 2D velocity vector",
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "description": "X velocity component",
          "type": "number"
        },
        "y": {
          "description": "Y velocity component",
          "type": "number"
        }
      }
    },
    "aimAngle": {
      "description": "Player aim angle in radians",
      "type": "number"
    },
    "weaponType": {
      "description": "Authoritative equipped weapon type for this player",
      "minLength": 1,
      "type": "string"
    },
    "health": {
      "description": "Current health",
      "minimum": 0,
      "type": "number"
    },
    "isInvulnerable": {
      "description": "Whether spawn invulnerability is active",
      "type": "boolean"
    },
    "invulnerabilityEnd": {
      "description": "RFC3339 timestamp when invulnerability ends",
      "type": "string"
    },
    "deathTime": {
      "description": "RFC3339 timestamp when the player died",
      "type": "string"
    },
    "kills": {
      "description": "Current kill count",
      "minimum": 0,
      "type": "integer"
    },
    "deaths": {
      "description": "Current death count",
      "minimum": 0,
      "type": "integer"
    },
    "xp": {
      "description": "Current XP total",
      "minimum": 0,
      "type": "integer"
    },
    "isRegenerating": {
      "description": "Whether the player is currently regenerating health",
      "type": "boolean"
    },
    "isRolling": {
      "description": "Whether the player is currently dodge rolling",
      "type": "boolean"
    }
  }
}
